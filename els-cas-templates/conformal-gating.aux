\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The conformal guarantee on real LLM behavior. (a) Realized harmful-skip rate vs.\ target $\alpha $ for both model families; the dashed line is $y=\alpha $. (b) Retrieval frequency falls monotonically as the budget loosens, so $\alpha $ is an interpretable cost dial. Mean over 10 calibration/test splits.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:dial}{{2}{5}{The conformal guarantee on real LLM behavior. (a) Realized harmful-skip rate vs.\ target $\alpha $ for both model families; the dashed line is $y=\alpha $. (b) Retrieval frequency falls monotonically as the budget loosens, so $\alpha $ is an interpretable cost dial. Mean over 10 calibration/test splits}{figure.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Coverage dial (Qwen2.5-3B, pooled). Realized harmful-skip rate tracks target $\alpha $; retrieval trades off monotonically.}}{5}{table.1}\protected@file@percent }
\newlabel{tab:dial}{{1}{5}{Coverage dial (Qwen2.5-3B, pooled). Realized harmful-skip rate tracks target $\alpha $; retrieval trades off monotonically}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces AUROC of ignorance signals for predicting wrongness (pooled, TriviaQA$+$PopQA). Discriminative power is near-identical; the operative difference is score granularity, not information (Section~\ref {sec:score}). Dashes indicate signals not computed for Phi-3.5-mini: the $k=8$ sampling budget for semantic entropy and self-consistency was allocated to Qwen for the primary granularity analysis; accordingly the \textsc  {IgnoranceModel} for Phi-3.5-mini uses neg.\ log-prob and answer length only, consistent with its AUROC of $0.888$.}}{5}{table.2}\protected@file@percent }
\newlabel{tab:auroc}{{2}{5}{AUROC of ignorance signals for predicting wrongness (pooled, TriviaQA$+$PopQA). Discriminative power is near-identical; the operative difference is score granularity, not information (Section~\ref {sec:score}). Dashes indicate signals not computed for Phi-3.5-mini: the $k=8$ sampling budget for semantic entropy and self-consistency was allocated to Qwen for the primary granularity analysis; accordingly the \textsc {IgnoranceModel} for Phi-3.5-mini uses neg.\ log-prob and answer length only, consistent with its AUROC of $0.888$}{table.2}{}}
